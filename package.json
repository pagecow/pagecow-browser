{
  "name": "pagecow-browser",
  "version": "1.0.14",
  "description": "PageCow - distraction-free study-only browser",
  "main": "electron/main.js",
  "author": "PageCow <pagecow@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 node scripts/run-electron.js .",
    "build": "vite build",
    "start": "node scripts/run-electron.js .",
    "pack": "npm run build && electron-builder --config electron-builder.yml --dir",
    "dist": "npm run build && electron-builder --config electron-builder.yml --publish never"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.14.1",
    "cross-fetch": "^4.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^38.4.0",
    "electron-builder": "^26.0.12",
    "vite": "^7.1.12",
    "wait-on": "^9.0.1"
  }
}
